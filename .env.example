# ==============================================================================
# 方圆智版 AI - 环境配置模板
# ==============================================================================
# 使用说明：
#   1. 复制此文件为 .env（开发环境）或 .env.prod（生产环境）
#   2. 填入您的真实密钥
#   3. 启动：docker compose up -d
#
# ⚠️ 安全警告：此文件包含敏感信息，请勿提交到版本控制系统
# ==============================================================================

# 基础网络与运行配置 
LOG_LEVEL=info
MODE=production
GRACEFUL_SHUTDOWN_TIMEOUT=30

# FastAPI Docs 接口开关（生产环境关闭，开发环境设为 true）
SHOW_DOCS=false
API_PREFIX_AGENT=/v1/agent

# ── 2. 核心大模型 API 密钥 ─────────────────────────────────────────────────
# ⚠️ 请填入您需要使用的大模型密钥（由 config.yaml 统一调度）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here
OLLAMA_API_KEY=ollama
MLX_API_KEY=mlx

# ── 3. 安全防护 ───────────────────────────────────────────────────────────
ENABLE_SAFEGUARD=true
LANGFUSE_TRACING=false

# ── 4. PostgreSQL 数据库 ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=fyzj_agent

# ==========================================
# 5. 数据库表名前缀配置（与根目录 .env 保持一致）
# ==========================================
# Agent 服务表名前缀 langgraph checkpointer 使用
POSTGRES_APPLICATION_NAME=agent_service

# Core 服务表名前缀（影响所有 core_* 表）
CORE_TABLE_PREFIX=core_
CHAT_SESSION_TABLE_NAME=chat_sessions

# Agent 服务表名前缀（影响所有 agent_server_* 表）
AGENT_TABLE_PREFIX=agent_server_


# 连接池配置
POSTGRES_MIN_CONNECTIONS_PER_POOL=5
POSTGRES_MAX_CONNECTIONS_PER_POOL=30
POSTGRES_POOL_OPEN_TIMEOUT=30
POSTGRES_POOL_CLOSE_TIMEOUT=10
POSTGRES_POOL_MAX_IDLE_TIME=300

# CORS 配置 
CORS_ORIGINS=http://localhost:3000,https://chat.fyzj.online

# NextAuth 认证配置
# 生成方式：openssl rand -base64 32
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32

# Embedding 配置 
EMBEDDING_DIM=1024

# 全局接口限流策略 
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ANONYMOUS=5/minute
RATE_LIMIT_AUTHENTICATED=50/minute

